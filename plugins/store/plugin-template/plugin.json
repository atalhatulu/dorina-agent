{
    "name": "plugin-template",
    "version": "1.0.0",
    "description": "Örnek plugin — manifest yapısını gösterir. Kopyalayıp kendi plugin'inizi oluşturun.",
    "author": "Dorina Agent",
    "hooks": [
        "on_tool_called",
        "on_session_start",
        "on_message"
    ],
    "commands": [
        {
            "name": "hello",
            "description": "Merhaba dünya — plugin test komutu",
            "parameters": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Selamlanacak kişi"
                    }
                }
            }
        }
    ],
    "skills": [
        {
            "name": "example-skill",
            "description": "Örnek bir beceri — plugin'lerin nasıl skill sağlayabileceğini gösterir",
            "triggers": ["example", "örnek", "plugin"]
        }
    ],
    "dependencies": [],
    "python": ">=3.10"
}
